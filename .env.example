# ═══════════════════════════════════════════════════════════════
# MediMentr Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Also used by the Vite frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Google Gemini AI (server-side only, NEVER expose to client) ─
GEMINI_API_KEY=your-gemini-api-key

# ── Resend Email Service ──────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
# Sender email (once your domain is verified in Resend)
EMAIL_FROM=Medimentr <noreply@yourdomain.com>
# Admin email for contact form submissions
ADMIN_EMAIL=admin@yourdomain.com

# ── Backend Security (Cloud Run) ─────────────────────────────
# Secret API key that Netlify proxy injects in X-API-Key header
# Generate one with: openssl rand -hex 32
BACKEND_API_KEY=your-random-secret-key

# ── CORS (Cloud Run) ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.netlify.app,https://yourdomain.com

# ── Application URL ──────────────────────────────────────────
# Used in email templates for links (no trailing slash)
APP_URL=https://www.medimentr.com

# ── Server ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
